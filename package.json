{
  "name": "remote-opencode-sandbox",
  "version": "0.1.0",
  "description": "Run OpenCode in a secure Docker sandbox, accessible via Discord. Multi-project, templated, auto-configured.",
  "type": "module",
  "author": "Omar ElGaml",
  "bin": {
    "sandbox": "./bin/sandbox.ts"
  },
  "scripts": {
    "dev": "bun run bin/sandbox.ts",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.3"
  }
}
